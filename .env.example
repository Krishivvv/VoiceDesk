# Copy this file to .env and fill in your values. Never commit your real .env.

# ---- LLM provider (required) ----
# Groq is the primary provider (free API key: https://console.groq.com/keys).
GROQ_API_KEY=REPLACE_WITH_YOUR_GROQ_API_KEY
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1

# Optional OpenAI fallback (used only if GROQ_API_KEY is unset).
# OPENAI_API_KEY=your_openai_api_key_here

# ---- Speech-to-Text (local Whisper, no key needed) ----
# Model size: tiny | base | small | medium | large. Use "tiny" on CPU-limited hosts.
WHISPER_MODEL=base

# ---- Text-to-Speech (Edge TTS, free, no key) ----
TTS_VOICE=en-US-AriaNeural

# ---- Server ----
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
DEBUG=false

# Comma-separated allowed CORS origins; "*" allows all (dev only).
ALLOWED_ORIGINS=*

# ---- Logging ----
LOG_LEVEL=INFO
